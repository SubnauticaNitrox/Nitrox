<UserControl
    d:DesignHeight="770"
    d:DesignWidth="927"
    mc:Ignorable="d"
    x:Class="Nitrox.Launcher.Views.LibraryView"
    x:DataType="vm:LibraryViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Nitrox.Launcher.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:designer="clr-namespace:Nitrox.Launcher.ViewModels.Designer"
    xmlns:converters="clr-namespace:Nitrox.Launcher.Models.Converters"
    xmlns:system="clr-namespace:System;assembly=System.Runtime"
    xmlns:design="clr-namespace:Nitrox.Launcher.Models.Design"
    xmlns:controls="clr-namespace:Nitrox.Launcher.Models.Controls">

    <Design.DataContext>
        <designer:DesignLibraryViewModel />
    </Design.DataContext>

    <ScrollViewer Classes="main">
       <StackPanel Background="{DynamicResource BrandWhite}"
                   Classes="viewPadding" Spacing="23">

           <Grid>
               <TextBlock Classes="header" Text="Library" />
               <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="5">
                   <Button Classes="primary"
                           Command="{Binding AddGameInstallationCommand}"
                           Content="Add game" />
                   <Button Content="Options">
                       <Button.Flyout>
                           <Flyout>
                               <StackPanel Orientation="Vertical" Spacing="2">
                                   <StackPanel.Styles>
                                       <Style Selector="Button">
                                           <Setter Property="Background" Value="Transparent" />
                                           <Setter Property="Padding" Value="8" />
                                           <Setter Property="HorizontalAlignment" Value="Stretch" />
                                           <Setter Property="HorizontalContentAlignment" Value="Left" />

                                           <Style Selector="^ StackPanel">
                                               <Setter Property="Spacing" Value="10" />
                                           </Style>

                                           <Style Selector="^ Image, ^ controls|RecolorImage, ^ Svg">
                                               <Setter Property="Width" Value="18" />
                                               <Setter Property="Height" Value="18" />
                                           </Style>
                                       </Style>
                                   </StackPanel.Styles>
                                   <Button Command="{Binding RemoveGameInstallationCommand}"
                                           CommandParameter="{Binding SelectedGame}"
                                           ToolTip.Tip="Remove the currently selected game installation from the Nitrox Launcher">
                                       <StackPanel>
                                           <Image Source="/Assets/Images/world-manager/delete.png" />
                                           <TextBlock Text="Remove selected installation" />
                                       </StackPanel>
                                   </Button>
                                   <Button Command="{Binding RemoveGameInstallationCommand}"
                                           CommandParameter="{Binding SelectedGame}"
                                           ToolTip.Tip="Recheck the system for any new, non-ignored game installations and add them to the list.">
                                       <StackPanel>
                                           <Svg Classes="theme" Path="/Assets/Icons/refresh.svg" />
                                           <TextBlock Text="Refresh game installations" />
                                       </StackPanel>
                                   </Button>
                               </StackPanel>
                           </Flyout>
                       </Button.Flyout>
                   </Button>
               </StackPanel>
           </Grid>

           <ScrollViewer HorizontalScrollBarVisibility="Auto">
               <Grid Height="335">
                   <TextBlock
                       Text="No game installations detected. You must add a game installation to use Nitrox."
                       FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"
                       IsVisible="{Binding !LibraryEntries.Count}" />
                   <!-- TODO: Stop list from reordering somehow when a different installation is selected -->
                   <ItemsControl ItemsSource="{Binding LibraryEntries}">
                       <ItemsControl.ItemsPanel>
                           <ItemsPanelTemplate>
                               <StackPanel Orientation="Horizontal" Spacing="20" />
                           </ItemsPanelTemplate>
                       </ItemsControl.ItemsPanel>
                       <ItemsControl.ItemTemplate>
                           <DataTemplate>
                               <RadioButton GroupName="LibraryEntries" Padding="0">
                                   <RadioButton.Styles>
                                       <Style Selector="RadioButton">
                                           <Setter Property="Template">
                                               <ControlTemplate>
                                                   <Button Background="Transparent"
                                                           Padding="0" CornerRadius="10"
                                                           Command="{Binding $parent[ItemsControl].((vm:LibraryViewModel)DataContext).SetSelectedGameCommand}" CommandParameter="{Binding}">
                                                       <Grid RowDefinitions="Auto, *, *" ColumnDefinitions="*, *">
                                                           <Image Grid.ColumnSpan="2" Source="/Assets/Images/subnautica-card.png" Width="210" Margin="0 0 0 12"/>
                                                           <TextBlock Grid.Row="1" HorizontalAlignment="Left" FontSize="16"
                                                                      FontWeight="Bold" Text="Subnautica" />
                                                           <controls:RecolorImage
                                                               Grid.Column="1" Grid.Row="1"
                                                               Height="15" Width="15"
                                                               HorizontalAlignment="Right"
                                                               Source="{Binding Platform, Converter={converters:PlatformToIconConverter}}"
                                                               Stretch="Uniform" />
                                                           <TextBlock Grid.Row="2" HorizontalAlignment="Left" FontSize="10"
                                                                      Margin="0 0 0 2"
                                                                      Foreground="{DynamicResource BrandSubText}" FontWeight="Bold"
                                                                      Text="{Binding Platform, Converter={converters:ToStringConverter}}"/>
                                                       </Grid>
                                                   </Button>
                                               </ControlTemplate>
                                           </Setter>
                                           <Style Selector="^[IsChecked=false]">
                                               <Setter Property="Opacity" Value="0.5" />
                                           </Style>
                                           <Style Selector="^[IsChecked=true] /template/ Button:pointerover">
                                               <Setter Property="Opacity" Value="1" />
                                           </Style>
                                       </Style>
                                   </RadioButton.Styles>
                                   <RadioButton.IsChecked>
                                       <MultiBinding Converter="{converters:EqualityConverter}">
                                           <Binding Path="PathToGame" />
                                           <Binding Path="$parent[ItemsControl].((vm:LibraryViewModel)DataContext).SelectedGame.PathToGame" />
                                       </MultiBinding>
                                   </RadioButton.IsChecked>
                               </RadioButton>
                           </DataTemplate>
                       </ItemsControl.ItemTemplate>
                   </ItemsControl>
               </Grid>
           </ScrollViewer>

           <TextBlock Text="RECENT SERVERS" Margin="0 15 0 -10" FontSize="10"
                      Foreground="{DynamicResource BrandSubText}" />

           <ItemsControl ItemsSource="{Binding RecentServers, Mode=OneWay}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel ItemSpacing="16" LineSpacing="16" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="421" Background="{DynamicResource BrandPanelBackground}"
                                CornerRadius="12" Padding="20">
                            <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="16">
                                <Border Height="56" Width="56"
                                        ClipToBounds="True"
                                        CornerRadius="12">
                                    <Grid>
                                        <Image IsVisible="{Binding ServerIcon, Converter={converters:EqualityConverter}}" Source="/Assets/Images/subnautica-icon.png" />
                                        <Border>
                                            <Border.Background>
                                                <ImageBrush Source="{Binding ServerIcon}" Stretch="UniformToFill" />
                                            </Border.Background>
                                        </Border>
                                        <controls:GrayscaleControl Opacity="{Binding !IsOnline}">
                                            <controls:GrayscaleControl.Transitions>
                                                <Transitions>
                                                    <DoubleTransition Duration="0:0:0.10" Property="Opacity" />
                                                </Transitions>
                                            </controls:GrayscaleControl.Transitions>
                                        </controls:GrayscaleControl>
                                    </Grid>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                    <TextBlock FontSize="16" FontWeight="Bold" Text="{Binding ServerName}" TextWrapping="NoWrap" />
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Spacing="12">
                                        <StackPanel.Styles>
                                            <Style Selector="StackPanel">
                                                <Style Selector="^ TextBlock">
                                                    <Setter Property="Opacity" Value="0.5" />
                                                </Style>
                                                <Style Selector="^ Ellipse">
                                                    <Setter Property="Height" Value="6" />
                                                    <Setter Property="Width" Value="6" />
                                                    <Setter Property="Margin" Value="0 0 6 0" />
                                                </Style>
                                            </Style>
                                        </StackPanel.Styles>
                                        <Panel>
                                            <StackPanel IsVisible="{Binding IsOnline}" Orientation="Horizontal">
                                                <Ellipse Fill="{DynamicResource BrandOnColor}" />
                                                <TextBlock IsVisible="{Binding IsOnline}" Text="Online" />
                                            </StackPanel>
                                            <StackPanel IsVisible="{Binding !IsOnline}" Orientation="Horizontal">
                                                <Ellipse Fill="{DynamicResource BrandOffColor}" />
                                                <TextBlock IsVisible="{Binding !IsOnline}" Text="Offline" />
                                            </StackPanel>
                                        </Panel>
                                        <TextBlock TextWrapping="NoWrap" Background="Transparent"
                                                   Classes.online="{Binding IsOnline}"
                                                   ToolTip.Tip="{Binding PlayerNamesTooltip}">
                                            <Run Text="{Binding PlayerCount}" />
                                            <Run Text=" / " />
                                            <Run Text="{Binding MaxPlayers}" />
                                            <Run Text=" playing" />
                                            <TextBlock.Styles>
                                                <Style Selector="TextBlock.online:pointerover">
                                                    <Setter Property="TextDecorations" Value="Underline" />
                                                </Style>
                                            </TextBlock.Styles>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                                <Button
                                    Classes="icon"
                                    Grid.Column="2"
                                    Width="24" Height="24"
                                    ToolTip.Tip="{Binding ServerAddressTooltip}">
                                    <Svg Classes="theme" Path="/Assets/Icons/info.svg" />
                                    <Button.Styles>
                                        <Style Selector="Button:pointerover">
                                            <Setter Property="Effect">
                                                <DropShadowDirectionEffect
                                                    BlurRadius="20"
                                                    Color="{DynamicResource BrandBlack}"
                                                    ShadowDepth="0" />
                                            </Setter>
                                        </Style>
                                    </Button.Styles>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

       </StackPanel>
    </ScrollViewer>
</UserControl>